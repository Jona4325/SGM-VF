# Archivos de entorno y credenciales
# No incluyas nunca archivos con secretos (API keys, contraseñas de BD) en el repositorio.
.env
local_settings.py
# Entornos virtuales de Python
# Ignora el directorio del entorno virtual para evitar subir cientos de archivos de dependencias.
env/
venv/
.venv/
# Archivos compilados y de caché de Python
# Estos archivos se generan automáticamente y no deben ser versionados.
__pycache__/
*.py[cod]
*.so
.cache
# Artefactos de empaquetado y distribución
build/
dist/
sdist/
*.egg-info/
*.egg
# Archivos de Django
# La base de datos local y los archivos estáticos/media generados no deben estar en el repo.
db.sqlite3
/staticfiles/
/media/
*.log
# Archivos de testing y cobertura
.coverage
htmlcov/
.tox/
nosetests.xml
coverage.xml

# Archivos de internacionalización
*.mo
# Archivos de sistema operativo (macOS, Windows)
Thumbs.db

# Archivos de configuración de IDEs y editores
# Ayuda a que cada desarrollador use su configuración sin afectar a los demás.
.idea/
.vscode/
*.sublime-project
*.sublime-workspace